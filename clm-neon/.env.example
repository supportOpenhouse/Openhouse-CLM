# ============================================================
# OPENHOUSE CLM — environment variables (Neon + NextAuth edition)
# Copy to .env.local for dev, set in Vercel dashboard for prod
# ============================================================

# --- Neon (Postgres) ---
# From neon.tech: your project's connection string. Use the pooled URL for the app,
# the direct URL for migrations (drizzle-kit push).
DATABASE_URL=postgres://user:password@ep-cool-darkness-xxx-pooler.ap-southeast-1.aws.neon.tech/clm?sslmode=require
DATABASE_URL_UNPOOLED=postgres://user:password@ep-cool-darkness-xxx.ap-southeast-1.aws.neon.tech/clm?sslmode=require

# --- NextAuth ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=your-random-32-byte-base64-string

# The URL NextAuth will use for redirects. Set to your Vercel deployment URL in prod.
# In dev this is typically http://localhost:3000
AUTH_URL=https://clm.openhouse.in

# --- Google OAuth ---
# From Google Cloud Console → Credentials → OAuth client ID (Web application)
AUTH_GOOGLE_ID=xxx.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=GOCSPX-xxx

# --- Anthropic ---
# Server-only; used by /api/ai/* routes
ANTHROPIC_API_KEY=sk-ant-...

# --- Resend (email notifications) ---
# From resend.com — verify your sending domain (e.g. noreply@openhouse.in)
RESEND_API_KEY=re_...
EMAIL_FROM="Openhouse CLM <noreply@openhouse.in>"

# --- App ---
NEXT_PUBLIC_APP_URL=https://clm.openhouse.in

# --- Domain restriction ---
NEXT_PUBLIC_ALLOWED_EMAIL_DOMAIN=openhouse.in
